{
  "name": "tentacles",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "for name in $(ls packages); do if [ \"$name\" != \"examples\" ]; then (cd \"packages/$name\" && yarn build) || exit $?; fi; done",
    "test": "vitest run",
    "test:leaks": "vitest run packages/core/tests/memory-leak.test.ts packages/core/tests/scope-leak.test.ts",
    "example": "yarn workspace examples dev",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "tsc --noEmit",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "2.3.11",
    "@vitest/coverage-v8": "^3",
    "effector": "^23.4.4",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-tabs": "^0.8.0",
    "vitest": "^3.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --diagnostic-level=error"
    ]
  },
  "resolutions": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
