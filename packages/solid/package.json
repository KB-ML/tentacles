{
  "name": "@kbml-tentacles/solid",
  "version": "2.0.0",
  "description": "Solid bindings for @kbml-tentacles/core.",
  "keywords": [
    "effector",
    "tentacles",
    "typescript",
    "reactive",
    "solid",
    "solid-js",
    "bindings"
  ],
  "license": "MIT",
  "author": "Nikita Lumpov",
  "homepage": "https://github.com/KB-ML/tentacles#readme",
  "bugs": {
    "url": "https://github.com/KB-ML/tentacles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KB-ML/tentacles.git",
    "directory": "packages/solid"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "solid": "./index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "index.ts",
    "view.tsx",
    "each.tsx",
    "use-model.ts",
    "types.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@kbml-tentacles/core": "^2.0.0",
    "effector": "^23.0.0",
    "effector-solid": "^0.23.0",
    "solid-js": ">=1.3.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "effector": "^23.4.4",
    "effector-solid": "^0.23.0",
    "happy-dom": "^20.8.9",
    "solid-js": "^1.9.0",
    "vite-plugin-solid": "^2.11.11"
  }
}
