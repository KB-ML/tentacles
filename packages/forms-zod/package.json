{
  "name": "@kbml-tentacles/forms-zod",
  "version": "1.0.0",
  "description": "Zod validation adapter for @kbml-tentacles/forms.",
  "keywords": [
    "effector",
    "tentacles",
    "typescript",
    "reactive",
    "forms",
    "validation",
    "zod"
  ],
  "license": "MIT",
  "author": "Nikita Lumpov",
  "homepage": "https://github.com/KB-ML/tentacles#readme",
  "bugs": {
    "url": "https://github.com/KB-ML/tentacles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KB-ML/tentacles.git",
    "directory": "packages/forms-zod"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@kbml-tentacles/core": "^1.0.0",
    "@kbml-tentacles/forms": "^1.0.0",
    "zod": ">=3.20"
  },
  "devDependencies": {
    "zod": "^4.3.6"
  }
}
