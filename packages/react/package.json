{
  "name": "@kbml-tentacles/react",
  "version": "2.0.0",
  "description": "React bindings for @kbml-tentacles/core.",
  "keywords": [
    "effector",
    "tentacles",
    "typescript",
    "reactive",
    "react",
    "bindings"
  ],
  "license": "MIT",
  "author": "Nikita Lumpov",
  "homepage": "https://github.com/KB-ML/tentacles#readme",
  "bugs": {
    "url": "https://github.com/KB-ML/tentacles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KB-ML/tentacles.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@kbml-tentacles/core": "^2.0.0",
    "effector": "^23.0.0",
    "effector-react": "^23.0.0",
    "react": ">=16.8.0 <20.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "effector": "^23.4.4",
    "effector-react": "^23.3.0",
    "happy-dom": "^20.8.9",
    "react": "^19.0.0",
    "react-dom": "^19.2.4"
  }
}
