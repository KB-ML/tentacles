{
  "name": "@kbml-tentacles/vue",
  "version": "0.1.2",
  "description": "Vue bindings for @kbml-tentacles/core.",
  "keywords": [
    "effector",
    "tentacles",
    "typescript",
    "reactive",
    "vue",
    "bindings"
  ],
  "license": "MIT",
  "author": "Nikita Lumpov",
  "homepage": "https://github.com/KB-ML/tentacles#readme",
  "bugs": {
    "url": "https://github.com/KB-ML/tentacles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KB-ML/tentacles.git",
    "directory": "packages/vue"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@kbml-tentacles/core": "^0.1.2",
    "effector": "^23.0.0",
    "effector-vue": "^23.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "effector": "^23.4.4",
    "effector-vue": "^23.1.1",
    "happy-dom": "^20.8.9",
    "vue": "^3.5.0"
  }
}
