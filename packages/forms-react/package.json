{
  "name": "@kbml-tentacles/forms-react",
  "version": "1.0.0",
  "description": "React bindings for @kbml-tentacles/forms.",
  "keywords": [
    "effector",
    "tentacles",
    "typescript",
    "reactive",
    "forms",
    "react"
  ],
  "license": "MIT",
  "author": "Nikita Lumpov",
  "homepage": "https://github.com/KB-ML/tentacles#readme",
  "bugs": {
    "url": "https://github.com/KB-ML/tentacles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KB-ML/tentacles.git",
    "directory": "packages/forms-react"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@kbml-tentacles/core": "^1.0.0",
    "@kbml-tentacles/forms": "^1.0.0",
    "effector": "^23.0.0",
    "effector-react": "^23.0.0",
    "react": ">=16.8.0 <20.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "effector": "^23.4.4",
    "effector-react": "^23.3.0",
    "react": "^19.0.0"
  }
}
